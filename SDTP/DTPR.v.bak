module DTPR(input clk);
    //Entradas y salidas de pc
    wire [31:0]entrada_pc;
    wire [31:0]salida_pc;

    //Salida de add para la direccion de pc + 4bits
    wire [31:0]cuatro_bits = 32'd4;
    wire [31:0]salida_add_pc;

    //Separacion de la intruccion de entrada de 32 bits.
    wire [31:0]inst;
    wire [5:0] op;
    wire [4:0] rs;
    wire [4:0] rt;
    wire [4:0] rd;
    wire [4:0] shamt;
    wire [5:0] funct;

    //Salidas del modulo "Unidad de Control".
    wire RegDst;
    wire Branch;
    wire MemToReg;
    wire MemToRead;
    wire MemToWrite;
    wire [2:0]ALUOp;
    wire RegWrite;
    wire ALUSrc;

    //Salida de "ALU Control".
    wire [3:0]Operation_ALU;

    //Entradas y salidas de la ALU.
    wire [31:0]op1;
    wire [31:0]op2;
    wire [31:0]op2_br;
    wire [31:0]res;

    //entrada y salida del MUX 2:1 final.
    wire [31:0] salida_rd;
    wire [31:0] final;

    //Se asigna el arreglo de bits correspondiente a cada variable.
    assign op    = inst[31:26];
    assign rs    = inst[25:21];
    assign rt    = inst[20:16];
    assign rd    = inst[15:11];
    assign shamt = inst[10:6];
    assign funct = inst[5:0];

    //cable para salida de rd del multiplexor 2:1 a banco de registros
    wire [4:0]rd_mux;
    wire [31:0] nada;
    wire nada_2;


    //Instanciado del modulo PC
    pc u_pc(
	.clk(clk),
	.entrada(entrada_pc),
	.dir(salida_pc)
    );

    //Instanciado del modulo Memoria Intrucciones
    mem_inst u_mem_inst(
	.RA(salida_pc),
	.rd(inst)
    );

    //Instanciado del modulo MUX 2:1 para la dir de memoria de instrucciones a banco de registros
    mux2a1 multiplexor2a1_memorias_rd(
        .entrada1(rt),
        .entrada2(rd),
        .selector(RegDst),
        .Resultado(rd_mux)
    );

    //Instanciado del modulo PO
    S32_comportamental u_S32_comp(
	.A_SUM(salida_pc),
	.B_SUM(cuatro_bits),
	.R_SUM(salida_add_pc)
    );

    //Instanciado del modulo MUX 2:1 para la salida de suma de 4 bits 
    mux2a1 multiplexor2a1_memorias_add(
        .entrada1(salida_add_pc),
        .entrada2(nada),
        .selector(nada_2),
        .Resultado(entrada_pc)
    );

    //Instanciado de los modulos correspondientes
    U_CONTROL U_C(
        .OP(op),
	.RegDst(RegDst),
	.Branch(Branch),
        .MemToReg(MemToReg),
        .MemToRead(MemToRead),
        .MemToWrite(MemToWrite),
        .ALUOp(ALUOp),
        .RegWrite(RegWrite),
	.ALUSrc(ALUSrc)
    );

    BR banco_registros(
        .RA1(rs),
        .RA2(rt),
        .WE(RegWrite),
        .AW(rd),
        .DW(final),
        .DR1(op1),
        .DR2(op2_br)
    );

    Alu_Control ALU_Control(
        .funct(funct),
        .ALUOp(ALUOp),
        .Operation(Operation_ALU)
    );

    //Instanciado del modulo MUX 2:1 para la salida de banco de registros
    mux2a1 multiplexor2a1_memorias_br(
        .entrada1(op2_br),
        .entrada2(nada),
        .selector(nada_2),
        .Resultado(entrada_pc)
    );

    ALUMIPS alu(
        .A(op1),
        .B(op2),
        .ALUct1(Operation_ALU),
        .R(res)
    );

    MEM rom(
        .WE(MemToWrite),
        .RE(MemToRead),
        .dir(res),
        .wd(op2),
        .rd(salida_rd)
    );

    mux2a1 multiplexor2a1_final(
        .entrada1(res),
        .entrada2(salida_rd),
        .selector(MemToReg),
        .Resultado(final)
    );

    assign resultado = final;

endmodule